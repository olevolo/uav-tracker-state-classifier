# dotenv sample — copy to `.env` (gitignored) for local experiments.
# Loaded by hydra/typer if present. Do NOT commit real tokens.

# Weights & Biases — we default to offline mode (local CSVs are primary).
WANDB_API_KEY=
WANDB_MODE=offline

# HuggingFace — needed when pulling certain tracker weights through Hub.
HF_TOKEN=
